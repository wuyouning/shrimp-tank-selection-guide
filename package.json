{
  "name": "openclaw-preflight",
  "version": "1.0.0",
  "description": "A host readiness CLI for OpenClaw that scores whether a machine is suitable for installation and day-to-day use.",
  "main": "dist/cli.js",
  "bin": {
    "openclaw-preflight": "dist/cli.js",
    "shrimp-tank": "dist/cli.js"
  },
  "directories": {
    "example": "examples"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:dev": "tsc",
    "clean": "rm -rf dist openclaw-preflight-*.tgz",
    "prepack": "npm run clean && npm run build",
    "start": "node dist/cli.js",
    "test": "npm run build:dev && node --test dist/**/*.test.js",
    "pack:local": "npm pack",
    "install:global-local": "npm run build && npm install -g .",
    "uninstall:global-local": "npm uninstall -g openclaw-preflight",
    "release:check": "npm run clean && npm test && npm pack",
    "build:dmg": "bash packaging/macos/build-dmg.sh"
  },
  "keywords": [
    "openclaw",
    "preflight",
    "cli",
    "host-readiness",
    "environment-check",
    "installation-check",
    "system-diagnostics",
    "developer-tools",
    "shrimp-tank"
  ],
  "author": "Wu Ruidong",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22.14"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
