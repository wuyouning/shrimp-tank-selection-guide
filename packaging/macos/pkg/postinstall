#!/bin/bash
set -euo pipefail

TARGET_HOME="${HOME:-/Users/$(stat -f%Su /dev/console)}"
INSTALL_ROOT="$TARGET_HOME/.shrimp-tank"
BIN_DIR="$INSTALL_ROOT/bin"
PAYLOAD_DIR="$INSTALL_ROOT/payload"
PKG_TGZ="$(ls "$PAYLOAD_DIR"/openclaw-preflight-*.tgz 2>/dev/null | head -n 1 || true)"

if [ -z "$PKG_TGZ" ]; then
  echo "Package tarball not found in $PAYLOAD_DIR"
  exit 1
fi

if ! command -v node >/dev/null 2>&1; then
  echo "Node.js 22.14+ is required before using Shrimp Tank."
  echo "Please install Node.js from https://nodejs.org/ and then run:"
  echo "  npm install -g $PKG_TGZ"
  exit 0
fi

npm install -g "$PKG_TGZ"

mkdir -p /usr/local/bin
cat >/usr/local/bin/shrimp-tank <<'EOF'
#!/bin/bash
exec openclaw-preflight "$@"
EOF
chmod +x /usr/local/bin/shrimp-tank

echo "Shrimp Tank installation completed."
echo "You can now run:"
echo "  openclaw-preflight --lang zh-CN"
echo "  shrimp-tank --lang en"
